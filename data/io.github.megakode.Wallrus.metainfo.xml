<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.megakode.Wallrus</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Wallrus</name>
  <summary>Create colorful abstract wallpapers</summary>
  <developer id="io.github.megakode">
    <name>Peter Boné</name>
  </developer>
  <description>
    <p>
      Wallrus lets you create colorful abstract wallpapers.
    </p><p>  
      Start with one of several preset patterns and add effects like distortion, lighting, and noise.
     </p><p>
     Pick a gradient from hundreds of bundled palettes or create your own, then export
      or set directly as your desktop wallpaper.
    </p>
  </description>
  <launchable type="desktop-id">io.github.megakode.Wallrus.desktop</launchable>
  <url type="homepage">https://github.com/megakode/wallrus</url>
  <url type="vcs-browser">https://github.com/megakode/wallrus</url>
  <screenshots>
    <screenshot type="default">
      <caption>Wallrus main window showing palette selection, pattern controls, and live preview</caption>
      <image>https://raw.githubusercontent.com/megakode/wallrus/main/data/screenshots/main.png</image>
    </screenshot>
  </screenshots>
  <branding>
    <color type="primary" scheme_preference="light">#ffbe6f</color>
    <color type="primary" scheme_preference="dark">#613583</color>
  </branding>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="1.2.2" date="2026-03-10">
    <description>
        <ul>
	<li>Fixed a bug where setting a wallpaper would fail</li>
        </ul>
    </description>
    </release>

    <release version="1.2.1" date="2026-03-07">
    <description>
        <ul>
        <li>New pattern types: Dunes, Spark</li>
        <li>Button to generate random presets</li>
        <li>New effect types</li>
        <li>Ability to save custom palettes</li>
        </ul>
    </description>
    </release>
  
    <release version="1.1.0" date="2026-02-26">
    <description>
        <ul>
        <li>Added ability to show palettes as gradients or colors</li>
        <li>Added phone to export resolution presets</li>
        </ul>
    </description>
    </release>
    <release version="1.0.0" date="2026-02-23">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>
  <provides>
    <binary>wallrus</binary>
  </provides>
</component>
